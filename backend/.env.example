# ── SERVEUR ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── BASE DE DONNÉES ────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/diasporalink

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=remplacez_par_une_clé_secrète_longue_et_aléatoire
JWT_EXPIRES_IN=7d

# ── TWILIO (SMS OTP) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── STRIPE (Paiement carte) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FIREBASE (Push notifications) ─────────────────────────
FIREBASE_PROJECT_ID=diasporalink
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@diasporalink.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── WEB PUSH VAPID ─────────────────────────────────────────
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:contact@diasporalink.com

# ── FRONTEND URL (CORS) ────────────────────────────────────
FRONTEND_URL=https://diasporalink.netlify.app

# ── CLOUDINARY (Photos colis) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=diasporalink
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
